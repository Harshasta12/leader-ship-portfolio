<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Leadership Portfolio — Rajan Iyer · March 2026</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Inter', sans-serif;
    background: #F9F8F5;
    color: #1A1A1A;
    min-height: 100vh;
    padding: 2rem 1rem;
  }

  .port {
    max-width: 720px;
    margin: 0 auto;
    background: #FFFFFF;
    border: 1px solid #E8E6E0;
    border-radius: 12px;
    padding: 2.5rem 3rem;
  }

  /* Header */
  .doc-eyebrow {
    font-size: 11px;
    letter-spacing: 0.08em;
    color: #888;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }
  .doc-name {
    font-family: 'DM Serif Display', serif;
    font-size: 36px;
    color: #1A1A1A;
    line-height: 1.1;
    margin-bottom: 6px;
  }
  .doc-role {
    font-size: 14px;
    color: #555;
    margin-bottom: 1.25rem;
  }
  .doc-meta {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    padding-bottom: 1.75rem;
    border-bottom: 1px solid #E8E6E0;
  }
  .doc-meta-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: #888;
  }
  .uid-pill {
    font-size: 11px;
    font-family: 'Courier New', monospace;
    background: #F3F2EE;
    border: 1px solid #E8E6E0;
    border-radius: 4px;
    padding: 2px 8px;
    color: #555;
    letter-spacing: 0.04em;
  }

  /* Signal band */
  .signal-band {
    padding: 1.75rem 0;
    border-bottom: 1px solid #E8E6E0;
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }
  .signal-bar {
    width: 3px;
    background: #C9A84C;
    flex-shrink: 0;
    align-self: stretch;
    min-height: 52px;
    border-radius: 0;
  }
  .signal-verdict {
    font-family: 'DM Serif Display', serif;
    font-size: 22px;
    color: #1A1A1A;
    line-height: 1.45;
  }
  .signal-sub {
    font-size: 13px;
    color: #777;
    margin-top: 8px;
  }
  .pace-tag {
    display: inline-block;
    font-size: 11px;
    font-weight: 500;
    font-family: 'Inter', sans-serif;
    letter-spacing: 0.05em;
    background: #FFF3CD;
    color: #7A5C00;
    border-radius: 4px;
    padding: 2px 8px;
    margin-left: 6px;
    vertical-align: middle;
  }

  /* Sections */
  .section {
    padding: 1.75rem 0;
    border-bottom: 1px solid #E8E6E0;
  }
  .section-label {
    font-size: 11px;
    letter-spacing: 0.08em;
    color: #999;
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  .section-title {
    font-family: 'DM Serif Display', serif;
    font-size: 22px;
    color: #1A1A1A;
    margin-bottom: 1rem;
  }
  .narrative {
    font-size: 15px;
    line-height: 1.8;
    color: #2A2A2A;
    margin-bottom: 1.25rem;
  }

  /* Stat cards */
  .stat-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 12px;
    margin-bottom: 1.25rem;
  }
  .stat-card {
    background: #F7F6F2;
    border-radius: 8px;
    padding: 1rem;
  }
  .stat-num {
    font-size: 30px;
    font-weight: 500;
    color: #1A1A1A;
    line-height: 1;
    margin-bottom: 4px;
  }
  .stat-label {
    font-size: 12px;
    color: #555;
  }
  .stat-sub {
    font-size: 11px;
    color: #999;
    margin-top: 2px;
  }

  /* Expand button */
  .expand-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: #555;
    background: none;
    border: 1px solid #DDD;
    border-radius: 8px;
    padding: 6px 14px;
    cursor: pointer;
    margin-top: 0.5rem;
    font-family: 'Inter', sans-serif;
    transition: background 0.15s;
  }
  .expand-btn:hover { background: #F7F6F2; }

  .collapse-content {
    margin-top: 1rem;
    display: none;
  }
  .collapse-content.open { display: block; }

  /* IP list */
  .ip-list { list-style: none; }
  .ip-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 10px 0;
    border-top: 1px solid #F0EFE9;
  }
  .ip-item:first-child { border-top: none; }
  .ip-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #C9A84C;
    flex-shrink: 0;
    margin-top: 6px;
  }
  .ip-text { font-size: 13px; color: #2A2A2A; line-height: 1.5; }
  .ip-date { font-size: 11px; color: #999; margin-top: 2px; }

  /* Axis bars */
  .axis-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 0.75rem;
  }
  .axis-row { display: flex; flex-direction: column; gap: 5px; }
  .axis-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .axis-name { font-size: 13px; color: #1A1A1A; font-weight: 500; }
  .axis-score { font-size: 13px; color: #777; }
  .axis-track {
    height: 7px;
    background: #F0EFE9;
    border-radius: 4px;
    position: relative;
    overflow: visible;
  }
  .axis-fill {
    height: 100%;
    border-radius: 4px;
  }
  .axis-fill.above { background: #2D9A6B; }
  .axis-fill.below { background: #C9A84C; }
  .threshold-line {
    position: absolute;
    top: -5px;
    width: 2px;
    height: 17px;
    background: #999;
    opacity: 0.5;
  }
  .threshold-label {
    position: absolute;
    top: -20px;
    font-size: 10px;
    color: #999;
    transform: translateX(-50%);
    white-space: nowrap;
    font-family: 'Inter', sans-serif;
  }
  .axis-note {
    font-size: 11px;
    color: #999;
    margin-top: 6px;
  }

  /* KPI table */
  .kpi-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
    margin-top: 0.75rem;
  }
  .kpi-table th {
    font-size: 11px;
    font-weight: 500;
    color: #999;
    text-align: left;
    padding: 0 0 8px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border-bottom: 1px solid #E8E6E0;
  }
  .kpi-table td {
    padding: 10px 0;
    border-bottom: 1px solid #F0EFE9;
    color: #2A2A2A;
    vertical-align: middle;
  }
  .kpi-table tr:last-child td { border-bottom: none; }
  .status-pill {
    display: inline-block;
    font-size: 11px;
    font-weight: 500;
    border-radius: 4px;
    padding: 2px 8px;
  }
  .pill-hit { background: #D4EDDA; color: #1A6B35; }
  .pill-miss { background: #FCE8E6; color: #8B2020; }
  .pill-partial { background: #FFF3CD; color: #7A5C00; }

  /* Constraint section */
  .constraint-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin: 1rem 0;
  }
  .c-card {
    background: #F7F6F2;
    border-radius: 8px;
    padding: 14px;
    text-align: center;
  }
  .c-num { font-size: 26px; font-weight: 500; color: #1A1A1A; }
  .c-label { font-size: 11px; color: #777; margin-top: 3px; }
  .resolution-bar-track {
    height: 8px;
    background: #F0EFE9;
    border-radius: 4px;
    overflow: hidden;
    margin: 1rem 0 4px;
  }
  .resolution-bar-fill {
    height: 100%;
    background: #2D9A6B;
    border-radius: 4px;
  }
  .resolution-label { font-size: 12px; color: #777; }

  /* Trajectory */
  .traj-section {
    padding: 1.75rem 0 0;
  }
  .runway {
    position: relative;
    height: 70px;
    margin: 1.75rem 0 0.5rem;
  }
  .runway-track {
    position: absolute;
    top: 32px;
    left: 0;
    right: 0;
    height: 2px;
    background: #E8E6E0;
  }
  .runway-progress {
    position: absolute;
    top: 32px;
    left: 0;
    width: 38%;
    height: 2px;
    background: #C9A84C;
  }
  .runway-nodes {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
  }
  .rnode {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }
  .rnode-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 2px solid #FFF;
    margin-top: 26px;
  }
  .rnode-dot.past { background: #2D9A6B; }
  .rnode-dot.current {
    background: #C9A84C;
    width: 16px;
    height: 16px;
    margin-top: 24px;
  }
  .rnode-dot.future {
    background: #E8E6E0;
    border-color: #CCC;
  }
  .rnode-label {
    font-size: 12px;
    color: #555;
    font-weight: 500;
    margin-top: 4px;
  }
  .rnode-date { font-size: 10px; color: #999; }
  .traj-next {
    margin-top: 1.25rem;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    background: #F7F6F2;
    border-radius: 8px;
  }
  .traj-next-icon {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: #FFF3CD;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 18px;
  }
  .traj-next-text { font-size: 14px; color: #1A1A1A; font-weight: 500; }
  .traj-next-sub { font-size: 12px; color: #777; margin-top: 3px; }

  /* Footer */
  .doc-footer {
    padding: 1.5rem 0 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 0.5rem;
    border-top: 1px solid #E8E6E0;
  }
  .footer-uid { font-size: 11px; color: #AAA; font-family: 'Courier New', monospace; }
  .footer-note { font-size: 11px; color: #AAA; }

  @media (max-width: 600px) {
    .port { padding: 1.5rem 1.25rem; }
    .doc-name { font-size: 28px; }
    .signal-verdict { font-size: 18px; }
    .constraint-grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>
</head>
